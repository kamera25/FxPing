{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "dialog:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "traceroute",
          "cmd": "/usr/sbin/traceroute",
          "args": true
        },
        {
          "name": "traceroute6",
          "cmd": "/usr/sbin/traceroute6",
          "args": true
        }
      ]
    },
    "shell:default",
    "fs:default"
  ]
}